---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="KIKU — Audio Tools for Android" description="Record, clean, and publish podcasts on Android. AI-powered tools for journalists and creators worldwide.">

  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-content container">
      <span class="badge animate-fade-up">Android Audio Tools</span>
      <h1 class="hero-title animate-fade-up delay-1">
        Listen smarter.<br/>Record safely.
      </h1>
      <p class="hero-sub animate-fade-up delay-2">
        AI-powered podcast player for smarter listening.<br/>
        Offline-first recording studio for safe field journalism.<br/>
        Two apps, built for Android.
      </p>
      <div class="hero-cta animate-fade-up delay-3">
        <a href="#products" class="btn btn-primary">Explore KIKU</a>
        <a href="#stories" class="btn btn-outline">See real stories</a>
      </div>
      <div class="hero-image animate-fade-up delay-4">
        <div class="hero-phones">
          <div class="phone-frame phone-left">
            <img src="/images/screenshot-player-main.jpg" alt="KIKU Player" class="phone-screen" />
          </div>
          <div class="phone-frame phone-right">
            <img src="/images/screenshot-studio-main.jpg" alt="KIKU Studio" class="phone-screen" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Social proof -->
  <section class="proof">
    <div class="container">
      <div class="proof-strip">
        <div class="proof-item">
          <span class="proof-number">Smart Speed</span>
          <span class="proof-label">Skip silence, save time</span>
        </div>
        <div class="proof-divider"></div>
        <div class="proof-item">
          <span class="proof-number">AI-powered</span>
          <span class="proof-label">Summaries, transcripts, noise reduction</span>
        </div>
        <div class="proof-divider"></div>
        <div class="proof-item">
          <span class="proof-number">Offline</span>
          <span class="proof-label">Studio works without internet</span>
        </div>
        <div class="proof-divider"></div>
        <div class="proof-item">
          <span class="proof-number">Free</span>
          <span class="proof-label">No subscriptions</span>
        </div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="how-it-works">
    <div class="container">
      <div class="section-divider"></div>
      <h2 class="section-title">How KIKU works</h2>
      <p class="section-sub">Two apps, two workflows — both designed for people who live on their phones.</p>
      <div class="dual-workflow">
        <div class="workflow-path">
          <div class="workflow-path-header">
            <div class="workflow-path-icon-wrap"><img src="/icon-player.svg" alt="" class="workflow-path-icon" /></div>
            <h3>KIKU Player</h3>
          </div>
          <div class="workflow-path-visual">
            <img src="/images/screenshot-player-detail.jpg" alt="KIKU Player playback" class="workflow-path-screenshot" />
          </div>
          <ol class="workflow-path-steps">
            <li>Subscribe to podcasts or import audio from any app</li>
            <li>Listen with Smart Speed and Voice Boost</li>
            <li>Read transcripts, get AI summaries, ask questions</li>
          </ol>
        </div>
        <div class="workflow-path">
          <div class="workflow-path-header">
            <div class="workflow-path-icon-wrap"><img src="/icon-studio.svg" alt="" class="workflow-path-icon" /></div>
            <h3>KIKU Studio</h3>
          </div>
          <div class="workflow-path-visual">
            <div class="denoise-compare">
              <div class="denoise-half">
                <span class="denoise-label">Before</span>
                <img src="/images/screenshot-denoise-before.jpg" alt="Noisy audio" class="denoise-img" />
              </div>
              <div class="denoise-half">
                <span class="denoise-label">After</span>
                <img src="/images/screenshot-denoise-after.jpg" alt="Clean audio" class="denoise-img" />
              </div>
            </div>
          </div>
          <ol class="workflow-path-steps">
            <li>Record in the field — one tap, 48kHz, battery-aware</li>
            <li>AI noise reduction and voice anonymization, all on-device</li>
            <li>Edit, transcribe, and share — no PC needed</li>
          </ol>
        </div>
      </div>
    </div>
  </section>

  <!-- Products -->
  <section class="products" id="products">
    <div class="container">
      <div class="section-divider"></div>
      <h2 class="section-title">Two apps, one mission</h2>
      <p class="section-sub">Make audio accessible to everyone — from Tokyo commuters to field journalists in Jakarta.</p>

      <div class="product-cards">
        <a href="/player" class="product-card">
          <div class="product-card-visual">
            <img src="/images/screenshot-player-detail.jpg" alt="KIKU Player playback screen" class="product-screenshot" />
          </div>
          <div class="product-card-content">
            <div class="product-icon-wrap">
              <img src="/icon-player.svg" alt="" class="product-icon-svg" />
            </div>
            <span class="badge">Podcast Player</span>
            <h3>KIKU Player</h3>
            <p class="product-tagline">Listen. Understand. Share what matters.</p>
            <ul class="product-features">
              <li>Smart Speed — skip silence automatically</li>
              <li>AI summaries & Q&A in your language</li>
              <li>Live transcripts with sync highlighting</li>
              <li>Import audio from Telegram, WhatsApp, any app</li>
            </ul>
            <span class="product-link">Learn more &rarr;</span>
          </div>
        </a>

        <a href="/studio" class="product-card card-studio">
          <div class="product-card-visual">
            <img src="/images/screenshot-studio-editor.jpg" alt="KIKU Studio waveform editor" class="product-screenshot" />
          </div>
          <div class="product-card-content">
            <div class="product-icon-wrap">
              <img src="/icon-studio.svg" alt="" class="product-icon-svg" />
            </div>
            <span class="badge">Podcast Studio</span>
            <h3>KIKU Studio</h3>
            <p class="product-tagline">Record. Protect. Publish safely.</p>
            <ul class="product-features">
              <li>AI noise reduction — one tap, on-device</li>
              <li>Voice anonymization for source protection</li>
              <li>Core features work fully offline</li>
              <li>Waveform editor with clip & share</li>
            </ul>
            <span class="product-link">Learn more &rarr;</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Stories / Personas -->
  <section class="stories" id="stories">
    <div class="container">
      <div class="section-divider"></div>
      <h2 class="section-title">Built for real workflows</h2>
      <p class="section-sub">From Tokyo commuters to Mumbai podcasters to Central American newsrooms.</p>

      <div class="story-grid">
        <div class="story-card story-featured">
          <div class="story-image">
            <img src="/images/persona-yuki.jpg" alt="Yuki on Tokyo commute" class="story-photo" />
          </div>
          <div class="story-content">
            <div class="story-product">KIKU Player</div>
            <blockquote>
              "I listen to English podcasts on my commute, read the transcript when I miss something, and ask AI to explain expressions in Japanese."
            </blockquote>
            <div class="story-author">
              <strong>Yuki, 26</strong>
              <span>English learner, Tokyo</span>
            </div>
          </div>
        </div>

        <div class="story-card">
          <div class="story-image">
            <img src="/images/persona-priya.jpg" alt="Priya recording at Mumbai market" class="story-photo" />
          </div>
          <div class="story-content">
            <div class="story-product">KIKU Studio</div>
            <blockquote>
              "I record interviews at the local market, remove the noise with one tap, cut the best parts, and share the episode — all from my phone. No PC needed."
            </blockquote>
            <div class="story-author">
              <strong>Priya, 32</strong>
              <span>Independent podcaster, Mumbai</span>
            </div>
          </div>
        </div>

        <div class="story-card">
          <div class="story-image">
            <img src="/images/persona-amirah.jpg" alt="Amirah with phone and notebook" class="story-photo" />
          </div>
          <div class="story-content">
            <div class="story-product">KIKU Player</div>
            <blockquote>
              "I receive 15-minute audio news on Telegram every morning. KIKU Player summarizes it with AI so I can share the key points to my WhatsApp team in 30 seconds."
            </blockquote>
            <div class="story-author">
              <strong>Amirah, 28</strong>
              <span>Freelance journalist, Jakarta</span>
            </div>
          </div>
        </div>

        <div class="story-card">
          <div class="story-image">
            <img src="/images/persona-daniel.jpg" alt="Daniel interviewing source" class="story-photo" />
          </div>
          <div class="story-content">
            <div class="story-product">KIKU Studio</div>
            <blockquote>
              "My sources' voices are anonymized before the audio leaves my device. Everything works offline — no data sent anywhere."
            </blockquote>
            <div class="story-author">
              <strong>Daniel, 35</strong>
              <span>Investigative journalist, Central America</span>
            </div>
          </div>
        </div>

        <div class="story-card">
          <div class="story-image">
            <img src="/images/persona-kofi.jpg" alt="Kofi editing audio clips" class="story-photo" />
          </div>
          <div class="story-content">
            <div class="story-product">KIKU Studio + Player</div>
            <blockquote>
              "I cut 1-minute clips from interviews and share them directly to WhatsApp Status. Full episodes get AI summaries for Twitter."
            </blockquote>
            <div class="story-author">
              <strong>Kofi, 24</strong>
              <span>Social media producer, Accra</span>
            </div>
          </div>
        </div>
      </div>
      <p class="stories-disclaimer">Names, portraits, and quotes are fictional, created to illustrate real-world use cases. Images generated with AI.</p>
    </div>
  </section>

  <!-- Why KIKU -->
  <section class="why">
    <div class="container">
      <div class="section-divider"></div>
      <h2 class="section-title">Why KIKU?</h2>
      <div class="why-grid">
        <div class="why-card">
          <div class="why-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3>Privacy-first</h3>
          <p>No user accounts. No tracking. Studio's noise reduction and voice anonymization run entirely on-device. AI features in both apps use your own API keys (BYOK) — we never see your data.</p>
        </div>
        <div class="why-card">
          <div class="why-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          </div>
          <h3>Android-native</h3>
          <p>Built with Kotlin and Jetpack Compose. Material Design 3 with Warm Amber theme. Not a cross-platform port — genuine Android quality.</p>
        </div>
        <div class="why-card">
          <div class="why-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          </div>
          <h3>Made for the world</h3>
          <p>Designed for podcast listeners and creators from Jakarta to Mumbai to Accra — where Android is the default and mobile is the primary device.</p>
        </div>
        <div class="why-card">
          <div class="why-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          </div>
          <h3>Free to start</h3>
          <p>Both apps are free to download with core features included. Optional one-time premium upgrade removes ads and unlocks advanced features. No subscriptions.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="final-cta">
    <div class="container">
      <div class="cta-card">
        <h2>Get started with KIKU</h2>
        <p>KIKU Player and KIKU Studio are coming soon to Google Play.</p>
        <div class="cta-buttons">
          <a href="/player" class="btn btn-primary">KIKU Player</a>
          <a href="/studio" class="btn btn-outline">KIKU Studio</a>
        </div>
        <p class="cta-note">Free to download. No account required.</p>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* Hero */
  .hero {
    position: relative;
    padding: calc(var(--space-section) + 2rem) 0 var(--space-section);
    text-align: center;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 50% 0%, var(--color-hero-gradient-end) 0%, transparent 70%),
      var(--color-surface);
    z-index: -1;
  }
  .hero-content {
    position: relative;
  }
  .hero-title {
    font-size: var(--text-hero);
    font-weight: 400;
    color: var(--color-on-surface);
    margin-top: 1.25rem;
    margin-bottom: 1.5rem;
  }
  .hero-sub {
    font-size: var(--text-body-lg);
    color: var(--color-on-surface-variant);
    max-width: 540px;
    margin: 0 auto 2.5rem;
    line-height: 1.7;
  }
  .hero-cta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 3rem;
  }
  .hero-image {
    max-width: 400px;
    margin: 0 auto;
  }
  .hero-phones {
    display: flex;
    justify-content: center;
    gap: 1.25rem;
    align-items: flex-end;
  }
  .phone-frame {
    width: 140px;
    border-radius: 18px;
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    border: 2px solid var(--color-outline-variant);
    background: var(--color-on-surface);
  }
  .phone-left {
    transform: rotate(-5deg) translateY(-6px);
  }
  .phone-right {
    transform: rotate(5deg) translateY(-6px);
  }
  .phone-screen {
    width: 100%;
    display: block;
  }

  /* Proof strip */
  .proof {
    padding: var(--space-block) 0;
    border-bottom: 1px solid var(--color-outline-variant);
  }
  .proof-strip {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .proof-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }
  .proof-number {
    font-family: var(--font-display);
    font-size: 1.75rem;
    color: var(--color-primary-light);
  }
  .proof-label {
    font-size: var(--text-sm);
    color: var(--color-on-surface-variant);
    font-weight: 500;
  }
  .proof-divider {
    width: 1px;
    height: 40px;
    background: var(--color-outline-variant);
  }

  /* How it works */
  .how-it-works {
    padding: var(--space-section) 0;
  }
  .section-title {
    font-size: var(--text-h2);
    text-align: center;
    color: var(--color-on-surface);
    margin-bottom: 0.75rem;
  }
  .section-sub {
    text-align: center;
    font-size: var(--text-body-lg);
    color: var(--color-on-surface-variant);
    max-width: 560px;
    margin: 0 auto 3rem;
  }
  .dual-workflow {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }
  .workflow-path {
    padding: 2rem;
    border-radius: var(--radius-lg);
    background: var(--color-surface-elevated);
    border: 1px solid var(--color-outline-variant);
    transition: all var(--duration-normal) var(--ease-out);
  }
  .workflow-path:hover {
    border-color: var(--color-primary-container);
    box-shadow: var(--shadow-md);
  }
  .workflow-path-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  .workflow-path-icon-wrap {
    width: 36px;
    height: 36px;
    padding: 6px;
    border-radius: 8px;
    background: var(--color-brand);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .workflow-path-icon {
    width: 24px;
    height: 24px;
    filter: brightness(0) invert(1);
  }
  .workflow-path-header h3 {
    font-size: var(--text-h3);
    color: var(--color-on-surface);
  }
  .workflow-path-visual {
    margin-bottom: 1.5rem;
  }
  .workflow-path-screenshot {
    width: 180px;
    border-radius: 16px;
    box-shadow: var(--shadow-md);
    border: 2px solid var(--color-outline-variant);
    display: block;
    margin: 0 auto;
  }
  .denoise-compare {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4px;
    background: var(--color-surface-variant);
    border-radius: var(--radius-md);
    overflow: hidden;
  }
  .denoise-half {
    position: relative;
  }
  .denoise-label {
    position: absolute;
    top: 6px;
    left: 6px;
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-on-brand);
    background: rgba(0,0,0,0.5);
    padding: 2px 8px;
    border-radius: 4px;
    z-index: 1;
  }
  .denoise-img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    object-position: center 28%;
    display: block;
  }
  .workflow-path-steps {
    list-style: none;
    counter-reset: step;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .workflow-path-steps li {
    counter-increment: step;
    font-size: var(--text-sm);
    color: var(--color-on-surface-variant);
    padding-left: 2rem;
    position: relative;
    line-height: 1.5;
  }
  .workflow-path-steps li::before {
    content: counter(step);
    position: absolute;
    left: 0;
    top: 0;
    width: 1.375rem;
    height: 1.375rem;
    border-radius: 50%;
    background: var(--color-brand);
    color: var(--color-on-brand);
    font-size: var(--text-xs);
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Products */
  .products {
    padding: var(--space-section) 0;
    background: var(--color-surface-variant);
  }
  .product-cards {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .product-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    padding: 2.5rem;
    border-radius: var(--radius-lg);
    background: var(--color-surface-elevated);
    box-shadow: var(--shadow-sm);
    text-decoration: none;
    color: var(--color-on-surface);
    transition: all var(--duration-normal) var(--ease-out);
    overflow: hidden;
  }
  .product-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
    text-decoration: none;
    color: var(--color-on-surface);
  }
  .product-card-visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .product-screenshot {
    width: 220px;
    border-radius: 20px;
    box-shadow: var(--shadow-md);
    border: 2px solid var(--color-outline-variant);
  }
  .product-card-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .product-icon-wrap {
    width: 56px;
    height: 56px;
    border-radius: 14px;
    background: var(--color-brand);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
  }
  .product-icon-svg {
    width: 36px;
    height: 36px;
    filter: brightness(0) invert(1);
  }
  .product-card-content .badge {
    align-self: flex-start;
    margin-bottom: 1rem;
  }
  .product-card-content h3 {
    font-size: var(--text-h2);
    margin-bottom: 0.5rem;
  }
  .product-tagline {
    font-size: var(--text-body);
    color: var(--color-primary);
    font-weight: 600;
    margin-bottom: 1.25rem;
  }
  .product-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    margin-bottom: 1.5rem;
  }
  .product-features li {
    font-size: var(--text-sm);
    color: var(--color-on-surface-variant);
    padding-left: 1.5rem;
    position: relative;
  }
  .product-features li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-brand);
  }
  .product-link {
    font-weight: 600;
    font-size: var(--text-sm);
    color: var(--color-primary);
  }
  .card-studio {
    direction: rtl;
  }
  .card-studio > * {
    direction: ltr;
  }

  /* Stories */
  .stories {
    padding: var(--space-section) 0;
  }
  .story-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }
  .story-card {
    background: var(--color-surface-elevated);
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-outline-variant);
    transition: all var(--duration-normal) var(--ease-out);
  }
  .story-card:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--color-primary-container);
  }
  .story-featured {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: 1fr 1fr;
  }
  .story-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .story-card:not(.story-featured) .story-photo {
    aspect-ratio: 16 / 9;
  }
  .story-content {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .story-product {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-primary-light);
    margin-bottom: 0.75rem;
  }
  .story-content blockquote {
    font-family: var(--font-display);
    font-size: var(--text-body-lg);
    color: var(--color-on-surface);
    line-height: 1.5;
    margin-bottom: 1.25rem;
