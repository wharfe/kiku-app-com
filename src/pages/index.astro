---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="Kiku — Audio Tools for Android">
  <section class="hero">
    <h1>Record. Protect. Share.</h1>
    <p class="hero-sub">
      Two apps, one mission: make audio accessible to everyone —
      from Tokyo commuters to field journalists in Jakarta.
    </p>
  </section>

  <section class="apps">
    <a href="/player" class="app-card">
      <div class="app-icon-wrap">
        <img src="/icon-player.svg" alt="Kiku Player" class="app-icon-svg" />
      </div>
      <h2>Kiku Player</h2>
      <p class="app-tagline">Listen. Understand. Share.</p>
      <p>Smart Speed, AI summaries, and real-time transcripts. The podcast player that helps you understand what you hear.</p>
      <span class="app-link">Learn more &rarr;</span>
    </a>

    <a href="/studio" class="app-card">
      <div class="app-icon-wrap">
        <img src="/icon-studio.svg" alt="Kiku Studio" class="app-icon-svg" />
      </div>
      <h2>Kiku Studio</h2>
      <p class="app-tagline">Record. Anonymize. Publish.</p>
      <p>Offline AI noise reduction, voice anonymization, and on-device transcription. Built for journalists who can't trust the cloud.</p>
      <span class="app-link">Learn more &rarr;</span>
    </a>
  </section>

  <section class="personas">
    <h2>Built for real people</h2>
    <div class="persona-grid">
      <div class="persona-card">
        <div class="persona-emoji">&#x1F4F1;</div>
        <h3>Priya, Mumbai</h3>
        <p class="persona-role">Independent podcaster</p>
        <p>"I record interviews at the local market, clean the audio with AI, and publish — all from my phone. No PC needed."</p>
      </div>
      <div class="persona-card">
        <div class="persona-emoji">&#x1F30D;</div>
        <h3>Daniel, Central America</h3>
        <p class="persona-role">Investigative journalist</p>
        <p>"My sources' voices are anonymized before the audio leaves my device. Everything works offline — no data sent anywhere."</p>
      </div>
      <div class="persona-card">
        <div class="persona-emoji">&#x1F3A7;</div>
        <h3>Yuki, Tokyo</h3>
        <p class="persona-role">English learner</p>
        <p>"I listen to English podcasts on my commute, read the transcript when I miss something, and ask AI to explain expressions."</p>
      </div>
      <div class="persona-card">
        <div class="persona-emoji">&#x1F4F2;</div>
        <h3>Amirah, Jakarta</h3>
        <p class="persona-role">Freelance journalist</p>
        <p>"I receive audio news on Telegram, get an AI summary in Kiku Player, and share the key points to my WhatsApp team."</p>
      </div>
      <div class="persona-card">
        <div class="persona-emoji">&#x1F4E3;</div>
        <h3>Kofi, Accra</h3>
        <p class="persona-role">Social media producer</p>
        <p>"I cut 1-minute clips from interviews and share them directly to WhatsApp Status. Full episodes get AI summaries for Twitter."</p>
      </div>
    </div>
  </section>

  <section class="why">
    <h2>Why Kiku?</h2>
    <div class="features">
      <div class="feature">
        <h3>Offline-first</h3>
        <p>AI noise reduction, voice anonymization, transcription — all on your device. No cloud, no subscriptions, no data leaving your phone.</p>
      </div>
      <div class="feature">
        <h3>Android-native</h3>
        <p>Built with Kotlin and Jetpack Compose. Material Design 3 with Warm Amber theme. Not a cross-platform port.</p>
      </div>
      <div class="feature">
        <h3>Made for the world</h3>
        <p>Designed for journalists and creators from Jakarta to Mumbai to Mexico City — where Android is the platform and connectivity is unreliable.</p>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    padding: 6rem 0 4rem;
    text-align: center;
  }
  .hero h1 {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 700;
    line-height: 1.1;
    color: var(--color-on-surface);
  }
  .hero-sub {
    margin-top: 1.5rem;
    font-size: 1.2rem;
    color: var(--color-on-surface-variant);
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
  }
  .apps {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
    padding: 2rem 0 4rem;
  }
  .app-card {
    display: block;
    padding: 2rem;
    border-radius: 1rem;
    background: var(--color-surface-variant);
    text-decoration: none;
    color: var(--color-on-surface);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .app-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.1);
    text-decoration: none;
  }
  .app-icon-wrap {
    width: 64px;
    height: 64px;
    border-radius: 16px;
    background: var(--color-primary-light);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
    overflow: hidden;
  }
  .app-icon-svg {
    width: 48px;
    height: 48px;
    filter: brightness(0) invert(1);
  }
  .app-card h2 {
    font-size: 1.5rem;
    font-weight: 700;
  }
  .app-tagline {
    font-size: 0.9rem;
    color: var(--color-primary);
    font-weight: 600;
    margin-bottom: 0.75rem;
  }
  .app-card p {
    color: var(--color-on-surface-variant);
    font-size: 0.95rem;
  }
  .app-link {
    display: inline-block;
    margin-top: 1rem;
    color: var(--color-primary);
    font-weight: 600;
    font-size: 0.9rem;
  }

  .personas {
    padding: 2rem 0 4rem;
  }
  .personas h2 {
    font-size: 2rem;
    font-weight: 700;
    text-align: center;
    margin-bottom: 2rem;
  }
  .persona-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
  }
  .persona-card {
    padding: 1.5rem;
    border-radius: 0.75rem;
    background: var(--color-surface-variant);
    border-left: 4px solid var(--color-primary-light);
  }
  .persona-emoji {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }
  .persona-card h3 {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
  }
  .persona-role {
    font-size: 0.8rem;
    color: var(--color-primary);
    font-weight: 600;
    margin-bottom: 0.75rem;
  }
  .persona-card p:last-child {
    font-size: 0.9rem;
    color: var(--color-on-surface-variant);
    font-style: italic;
  }

  .why {
    padding: 2rem 0 4rem;
  }
  .why h2 {
    font-size: 2rem;
    font-weight: 700;
    text-align: center;
    margin-bottom: 2rem;
  }
  .features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 2rem;
  }
  .feature h3 {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--color-primary);
  }
  .feature p {
    color: var(--color-on-surface-variant);
    font-size: 0.95rem;
  }
</style>
