---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="KIKU Studio — Offline-First Podcast Studio for Android" description="Record, anonymize voices, and share — all on your Android phone. On-device AI noise reduction. Built for journalists who need privacy." ogImage="/images/screenshot-studio-main.jpg">

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "KIKU Studio",
    "operatingSystem": "Android",
    "applicationCategory": "MultimediaApplication",
    "description": "Record, anonymize voices, and share — all on your Android phone. On-device AI noise reduction. Built for journalists who need privacy.",
    "inLanguage": ["en", "hi", "id"],
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-content container">
      <div class="hero-top">
        <div class="hero-text">
          <div class="hero-icon-wrap animate-fade-up">
            <img src="/icon-studio.svg" alt="" class="hero-icon-svg" />
          </div>
          <span class="badge animate-fade-up delay-1">Offline-First Studio</span>
          <h1 class="animate-fade-up delay-2">Record. Protect.<br/>Share safely.</h1>
          <p class="hero-sub animate-fade-up delay-3">
            The podcast studio that works without internet, without sending your data anywhere,
            and helps protect your sources' identity.
          </p>
          <div class="hero-cta animate-fade-up delay-4">
            <span class="btn btn-primary">Coming soon to Google Play</span>
          </div>
        </div>
        <div class="hero-visual animate-fade-up delay-3">
          <div class="phone-frame">
            <img src="/images/screenshot-studio-main.jpg" alt="KIKU Studio recording interface" class="phone-screen" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Scenario: Daniel -->
  <section class="scenario">
    <div class="container">
      <div class="scenario-inner scenario-reverse">
        <div class="scenario-content">
          <div class="scenario-label">Source protection</div>
          <blockquote>
            "I interview whistleblowers. Their voices are pitch-shifted before the recording leaves my device. Everything runs offline — no data sent to any server."
          </blockquote>
          <div class="scenario-author">
            <strong>Daniel, 35</strong>
            <span>Investigative journalist, Central America</span>
          </div>
        </div>
        <div class="scenario-image">
          <img src="/images/persona-daniel.jpg" alt="Daniel recording interview" class="scenario-photo" loading="lazy" width="200" height="200" />
        </div>
      </div>
    </div>
  </section>

  <!-- Trust features — the big 3 -->
  <section class="trust-features">
    <div class="container">
      <div class="section-divider"></div>
      <h2 class="section-title">Built for journalists who can't trust the cloud</h2>
      <p class="section-sub">Noise reduction and voice anonymization run entirely on-device. No internet required for core privacy features.</p>

      <div class="trust-grid">
        <div class="trust-card">
          <div class="trust-icon">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3>Voice Anonymization</h3>
          <p>Pitch-shift voice modification to help reduce speaker recognizability. Adjustable strength. Designed for source protection in the field.</p>
          <div class="trust-detail">TD-PSOLA, pure Kotlin, no dependencies</div>
        </div>
        <div class="trust-card">
          <div class="trust-icon">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          </div>
          <h3>Fully Offline</h3>
          <p>AI noise reduction and voice anonymization run entirely on-device. Transcription works offline with whisper.cpp, or via OpenAI Whisper API with your own key.</p>
          <div class="trust-detail">DeepFilterNet3 (Rust/JNI) + whisper.cpp (C/JNI)</div>
        </div>
        <div class="trust-card">
          <div class="trust-icon">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
          </div>
          <h3>No Metadata</h3>
          <p>Exported audio files contain no location, device info, or timestamps. UUID filenames prevent timing analysis.</p>
          <div class="trust-detail">FLAG_SECURE option for screen capture protection</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Studio features -->
  <section class="studio-features">
    <div class="container">
      <div class="section-divider"></div>
      <h2 class="section-title">Complete podcast toolkit</h2>
      <p class="section-sub">Record, clean, edit, transcribe, and share — all from your phone.</p>

      <div class="feature-grid">
        <div class="feature-card feature-wide">
          <div class="feature-card-inner">
            <div class="feature-info">
              <h3>AI Noise Reduction</h3>
              <p>DeepFilterNet3 removes background noise on-device. One tap transforms noisy field recordings into studio quality. No cloud, no cost, no waiting.</p>
              <div class="feature-spec">Rust/JNI, ~20 seconds for 10 minutes of audio on midrange phones</div>
            </div>
            <div class="feature-visual">
              <div class="denoise-compare">
                <div class="denoise-half">
                  <span class="denoise-label">Before</span>
                  <img src="/images/screenshot-denoise-before.jpg" alt="Noisy audio waveform" class="denoise-img" loading="lazy" />
                </div>
                <div class="denoise-half">
                  <span class="denoise-label">After</span>
                  <img src="/images/screenshot-denoise-after.jpg" alt="Clean audio waveform" class="denoise-img" loading="lazy" />
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="feature-card">
          <div class="feature-accent"></div>
          <h3>Field Recording</h3>
          <p>48kHz lossless recording with real-time waveform monitoring, pause/resume, Bluetooth warning, and storage checks.</p>
        </div>

        <div class="feature-card">
          <div class="feature-accent"></div>
          <h3>Waveform Editor</h3>
          <p>Cut, trim, undo/redo with pinch-to-zoom. Chapter markers for show notes. Non-destructive editing with 20-level undo.</p>
        </div>

        <div class="feature-card feature-wide">
          <div class="feature-card-inner feature-card-inner-reverse">
            <div class="feature-visual">
              <img src="/images/screenshot-studio-transcription.jpg" alt="On-device transcription" class="feature-screenshot" loading="lazy" width="240" height="520" />
            </div>
            <div class="feature-info">
              <h3>Transcription</h3>
              <p>Two options: whisper.cpp running locally on your phone (download ~75MB model once), or bring your own OpenAI API key for cloud transcription. Copy or share text directly.</p>
              <div class="feature-spec">On-device: whisper.cpp (C/JNI) | Cloud: OpenAI Whisper API (BYOK)</div>
            </div>
          </div>
        </div>

        <div class="feature-card">
          <div class="feature-accent"></div>
          <h3>Clip & Share</h3>
          <p>Select a highlight, export as a clip, and share directly via WhatsApp, Telegram, or any app. Perfect for social media.</p>
        </div>

        <div class="feature-card">
          <div class="feature-accent"></div>
          <h3>Double-Ender Recording</h3>
          <p>Each participant records locally. Auto-align by timestamp and mix — no call quality compromise.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Scenario: Priya -->
  <section class="scenario">
    <div class="container">
      <div class="scenario-inner">
        <div class="scenario-image">
          <img src="/images/persona-priya.jpg" alt="Priya recording at Mumbai market" class="scenario-photo" loading="lazy" width="200" height="200" />
        </div>
        <div class="scenario-content">
          <div class="scenario-label">Mobile-first podcasting</div>
          <blockquote>
            "I record interviews at the local market, remove the noise with one tap, cut the best parts, and share the episode — all from my phone. No PC needed."
          </blockquote>
          <div class="scenario-author">
            <strong>Priya, 32</strong>
            <span>Independent podcaster, publishes biweekly, Mumbai</span>
          </div>
        </div>
      </div>
      <p class="scenario-disclaimer">Names, portraits, and quotes are fictional, created to illustrate real-world use cases. Images generated with AI.</p>
    </div>
  </section>

  <!-- Privacy note -->
  <section class="privacy-section">
    <div class="container-narrow">
      <div class="privacy-card">
        <h2>A note on privacy</h2>
        <p>
          KIKU Studio is free, with no ads and no tracking. Voice anonymization uses pitch shifting,
          which helps reduce speaker recognizability but cannot guarantee complete anonymity — speech patterns,
          content, and environmental sounds may still allow identification by a determined adversary.
          For maximum protection, combine with device encryption and a strong lock screen.
        </p>
      </div>
    </div>
  </section>

  <!-- Technical specs -->
  <section class="specs-section">
    <div class="container">
      <div class="section-divider"></div>
      <h2 class="section-title">Under the hood</h2>
      <div class="specs-grid">
        <div class="spec-group">
          <h4>Recording</h4>
          <ul>
            <li>48kHz / 16-bit mono PCM</li>
            <li>AAudio low-latency API</li>
            <li>Real-time waveform display</li>
          </ul>
        </div>
        <div class="spec-group">
          <h4>Processing</h4>
          <ul>
            <li>DeepFilterNet3 (Rust/JNI)</li>
            <li>EBU R128 normalization (-16 LUFS)</li>
            <li>Energy-based VAD trimming</li>
          </ul>
        </div>
        <div class="spec-group">
          <h4>Privacy</h4>
          <ul>
            <li>TD-PSOLA voice anonymization</li>
            <li>UUID filenames, no metadata</li>
            <li>FLAG_SECURE option</li>
          </ul>
        </div>
        <div class="spec-group">
          <h4>Requirements</h4>
          <ul>
            <li>Android 8.0+ (API 26)</li>
            <li>Recommended 4GB+ RAM</li>
            <li>~39MB app size</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Cross-sell -->
  <section class="cross-sell">
    <div class="container">
      <div class="cross-sell-card">
        <div class="cross-sell-icon">
          <img src="/icon-player.svg" alt="" class="cross-sell-icon-svg" />
        </div>
        <div class="cross-sell-content">
          <h2>Listen with KIKU Player</h2>
          <p>Smart Speed, AI summaries, and real-time transcripts. The podcast player that helps you understand what you hear.</p>
          <a href="/player" class="btn btn-outline">Learn about Player &rarr;</a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* Hero */
  .hero {
    position: relative;
    padding: calc(var(--space-section) + 2rem) 0 var(--space-block);
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 50% at 70% 0%, var(--color-hero-gradient-end) 0%, transparent 70%),
      var(--color-surface);
    z-index: -1;
  }
  .hero-top {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }
  .hero-text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  .hero-icon-wrap {
    width: 72px;
    height: 72px;
    border-radius: 18px;
    background: var(--color-brand);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
    box-shadow: var(--shadow-glow);
  }
  .hero-icon-svg {
    width: 48px;
    height: 48px;
    filter: brightness(0) invert(1);
  }
  .hero h1 {
    font-size: var(--text-h1);
    color: var(--color-on-surface);
    margin-top: 1rem;
    margin-bottom: 1.25rem;
  }
  .hero-sub {
    font-size: var(--text-body-lg);
    color: var(--color-on-surface-variant);
    line-height: 1.7;
    margin-bottom: 2rem;
  }
  .hero-visual {
    display: flex;
    justify-content: center;
  }
  .phone-frame {
    width: 240px;
    border-radius: 28px;
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    border: 3px solid var(--color-outline-variant);
    background: var(--color-on-surface);
  }
  .phone-screen {
    width: 100%;
    display: block;
  }

  /* Scenarios */
  .scenario {
    padding: var(--space-block) 0;
  }
  .scenario-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }
  .scenario-reverse {
    direction: rtl;
  }
  .scenario-reverse > * {
    direction: ltr;
  }
  .scenario-photo {
    width: 100%;
    border-radius: var(--radius-lg);
    object-fit: cover;
    aspect-ratio: 4 / 3;
  }
  .scenario-label {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-primary-light);
    margin-bottom: 0.75rem;
  }
  .scenario-content blockquote {
    font-family: var(--font-display);
    font-size: 1.35rem;
    color: var(--color-on-surface);
    line-height: 1.5;
    margin-bottom: 1.25rem;
  }
  .scenario-author {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }
  .scenario-author strong {
    font-size: var(--text-sm);
  }
  .scenario-author span {
    font-size: var(--text-xs);
    color: var(--color-on-surface-variant);
  }

  /* Trust features */
  .trust-features {
    padding: var(--space-section) 0;
    background: var(--color-surface-variant);
  }
  .section-title {
    font-size: var(--text-h2);
    text-align: center;
    color: var(--color-on-surface);
    margin-bottom: 0.75rem;
  }
  .section-sub {
    text-align: center;
    font-size: var(--text-body-lg);
    color: var(--color-on-surface-variant);
    max-width: 560px;
    margin: 0 auto 3rem;
  }
  .trust-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .trust-card {
    padding: 2rem;
    border-radius: var(--radius-lg);
    background: var(--color-surface-elevated);
    border: 2px solid var(--color-primary-container);
    transition: all var(--duration-normal) var(--ease-out);
  }
  .trust-card:hover {
    border-color: var(--color-primary-light);
    box-shadow: var(--shadow-md);
  }
  .trust-icon {
    width: 56px;
    height: 56px;
    border-radius: 14px;
    background: var(--color-brand);
    color: var(--color-on-brand);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
  }
  .trust-card h3 {
    font-size: var(--text-h3);
    color: var(--color-on-surface);
    margin-bottom: 0.5rem;
  }
  .trust-card p {
    font-size: var(--text-sm);
    color: var(--color-on-surface-variant);
    line-height: 1.6;
    margin-bottom: 1rem;
  }
  .trust-detail {
    font-size: var(--text-xs);
    color: var(--color-outline);
    font-family: var(--font-body);
    font-weight: 500;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-outline-variant);
  }

  /* Studio features */
  .studio-features {
    padding: var(--space-section) 0;
  }
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }
  .feature-card {
    padding: 2rem;
    border-radius: var(--radius-lg);
    background: var(--color-surface-elevated);
    border: 1px solid var(--color-outline-variant);
    transition: all var(--duration-normal) var(--ease-out);
  }
  .feature-card:hover {
    border-color: var(--color-primary-container);
    box-shadow: var(--shadow-md);
  }
  .feature-accent {
    width: 40px;
    height: 3px;
    background: var(--color-brand);
    border-radius: 2px;
    margin-bottom: 1.25rem;
  }
  .feature-card h3 {
    font-size: var(--text-h3);
    color: var(--color-on-surface);
    margin-bottom: 0.5rem;
  }
  .feature-card p {
    font-size: var(--text-sm);
    color: var(--color-on-surface-variant);
    line-height: 1.6;
  }
  .feature-wide {
    grid-column: 1 / -1;
  }
  .feature-card-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
    align-items: center;
  }
  .feature-card-inner-reverse {
    direction: rtl;
  }
  .feature-card-inner-reverse > * {
    direction: ltr;
  }
  .feature-info h3 {
    font-size: 1.5rem;
  }
  .feature-info p {
    font-size: var(--text-body);
  }
  .feature-spec {
    margin-top: 0.75rem;
    font-size: var(--text-xs);
    color: var(--color-outline);
    font-weight: 500;
  }
  .feature-screenshot {
    width: 240px;
    border-radius: 20px;
    box-shadow: var(--shadow-md);
    border: 2px solid var(--color-outline-variant);
    margin: 0 auto;
    display: block;
  }
  .denoise-compare {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4px;
    background: var(--color-surface-variant);
    border-radius: var(--radius-md);
    overflow: hidden;
  }
  .denoise-half {
    position: relative;
  }
  .denoise-label {
    position: absolute;
    top: 8px;
    left: 8px;
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-on-brand);
    background: rgba(0,0,0,0.5);
    padding: 2px 10px;
    border-radius: 4px;
    z-index: 1;
  }
  .denoise-img {
    width: 100%;
    aspect-ratio: 9 / 14;
    object-fit: cover;
    object-position: center 30%;
    display: block;
  }

  .scenario-disclaimer {
    margin-top: 1.5rem;
    font-size: var(--text-xs);
    color: var(--color-outline);
    text-align: center;
    font-style: italic;
  }

  /* Privacy */
  .privacy-section {
    padding: var(--space-block) 0;
  }
  .privacy-card {
    padding: 2.5rem;
    background: var(--color-surface-variant);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-outline-variant);
    text-align: center;
  }
  .privacy-card h2 {
    font-size: var(--text-h3);
    color: var(--color-on-surface);
    margin-bottom: 0.75rem;
  }
  .privacy-card p {
    font-size: var(--text-sm);
    color: var(--color-on-surface-variant);
    line-height: 1.7;
  }

  /* Specs */
  .specs-section {
    padding: var(--space-section) 0;
    background: var(--color-surface-variant);
  }
  .specs-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }
  .spec-group h4 {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-primary-light);
    margin-bottom: 0.75rem;
  }
  .spec-group ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .spec-group li {
    font-size: var(--text-sm);
    color: var(--color-on-surface-variant);
    padding-left: 1rem;
    position: relative;
  }
  .spec-group li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--color-outline);
  }

  /* Cross-sell */
  .cross-sell {
    padding: var(--space-section) 0;
  }
  .cross-sell-card {
    display: flex;
    align-items: center;
    gap: 2rem;
    padding: 3rem;
    border-radius: var(--radius-xl);
    background: var(--color-surface-variant);
    border: 1px solid var(--color-outline-variant);
  }
  .cross-sell-icon {
    width: 64px;
    height: 64px;
    border-radius: 16px;
    background: var(--color-brand);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .cross-sell-icon-svg {
    width: 40px;
    height: 40px;
    filter: brightness(0) invert(1);
  }
  .cross-sell-content h2 {
    font-size: var(--text-h3);
    margin-bottom: 0.375rem;
  }
  .cross-sell-content p {
    font-size: var(--text-sm);
    color: var(--color-on-surface-variant);
    margin-bottom: 1rem;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero-top {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .hero-text {
      align-items: center;
    }
    .phone-frame {
      width: 200px;
    }
    .scenario-inner,
    .scenario-reverse {
      grid-template-columns: 1fr;
      gap: 1.5rem;
      direction: ltr;
    }
    .trust-grid {
      grid-template-columns: 1fr;
    }
    .feature-grid {
      grid-template-columns: 1fr;
    }
    .feature-card-inner,
    .feature-card-inner-reverse {
      grid-template-columns: 1fr;
      gap: 1.5rem;
      direction: ltr;
    }
    .specs-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .cross-sell-card {
      flex-direction: column;
      text-align: center;
      padding: 2rem;
    }
  }

  @media (max-width: 480px) {
    .specs-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
